{
  "user_name": "",
  "mcpServers": {
    "github": {
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp/",
      "timeout": 120,
      "headers": {
        "Authorization": "Bearer YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "mcp-imagineer": {
      "enabled": false,
      "url": "http://localhost:18080/sse",
      "timeout": 120
    },
    "huggingface": {
      "enabled": true,
      "url": "https://huggingface.co/mcp",
      "timeout": 120,
      "auto_approve": true
    },
    "canva": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.canva.com/mcp"],
      "timeout": 120
    },
	"mcp-mermaid": {
      "enabled": true,
	  "command": "cmd",
      "args": ["/c", "mcp-mermaid"],
	  "timeout": 120
    }
  },
  "llm_query": {
    "api_url": "http://localhost:11434",
    "model": "qwen3.5:397b-cloud",
    "temperature": 0.3,
    "timeout": 120
  },
  "web_fetch": {
    "llm_model": "qwen3.5:397b-cloud",
    "llm_summarize": true,
    "max_chars": 3000
  },
  "skills": {
    "graph-ai": {
      "model": "glm-5.1:cloud",
      "base_url": "http://localhost:11434",
      "api_key": "ollama-local",
      "max_tokens": 131072
    }
  },
  "tools": {
    "image_analysis": {
      "base_url": "http://localhost:11434/",
      "model": "gemma4:31b-cloud"
    },
    "google_calendar": {
      "credentials_path": "gs-cred.json",
      "calendar_id": "yourcalendarid_email",
      "timezone": "Asia/Tbilisi"
    },
	"google_search": {
	  "enabled":false,
	  "api_key": "... your-api-key...",
      "cx": "your-search-engine-id..."
	}
  }
}
